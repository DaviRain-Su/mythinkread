# MyThinkRead environment variables (copy to .env.local and fill in real secrets)

# Runtime mode: 'development' allows mock fallbacks; 'production' enforces real secrets and disables mocks.
ENVIRONMENT=development

# JWT signing secret. REQUIRED in production — must be a strong random string.
# Set via `wrangler secret put JWT_SECRET` for production.
JWT_SECRET=dev-only-insecure-secret-change-me

# Pinata JWT for IPFS pinning. REQUIRED in production.
# Get one at https://app.pinata.cloud/keys
PINATA_JWT=

# Bundlr / Irys private key for Arweave uploads. REQUIRED in production.
# This should be a JSON-serialised Solana keypair (output from `solana-keygen new`).
# It is used by the modern Irys SDK with Solana payment.
BUNDLR_PRIVATE_KEY=

# Azure TTS key for text-to-speech generation. Optional; falls back to Cloudflare Workers AI if absent.
AZURE_TTS_KEY=
